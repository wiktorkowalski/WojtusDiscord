# PostgreSQL (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=discord_events

# DiscordEventService configuration
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=discord_events;Username=postgres;Password=your_secure_password_here
Discord__Token=your_discord_bot_token_here

# OpenRouter (meme indexing + conversational assistant). The conversational assistant
# reuses this key; the chat model is set via Conversation__Model (default sonnet).
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Conversational assistant (#238). Channels where an @mention opens a thread (repeat the
# suffix index per entry); DMs always work. Langfuse keys are optional — without them the
# feature runs, traces just aren't exported.
Conversation__ChannelAllowList__0=
Conversation__LangfuseHost=
Conversation__LangfusePublicKey=
Conversation__LangfuseSecretKey=
